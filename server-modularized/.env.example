# .env.example — Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------

# TCP port the HTTP server listens on.
PORT=3001

# Runtime environment. Use "production" in deployed environments.
# Controls CORS policy, CSRF enforcement, and other security settings.
NODE_ENV=development

# Application version string returned by GET /api/version.
# Optional — defaults to "dev".
APP_VERSION=1.0.0

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------

# PostgreSQL / Neon / Turso connection string.
# Examples:
#   postgres://user:password@host:5432/dbname       (PostgreSQL / Neon)
#   libsql://your-db.turso.io?authToken=TOKEN       (Turso)
DATABASE_URL=postgres://user:password@localhost:5432/mydb

# Turso-specific URL (alternative to DATABASE_URL for Turso).
# If set, this takes precedence and DATABASE_URL is overwritten at startup.
TURSO_URL=
TURSO_DATABASE_URL=

# PostgreSQL connection pool tuning (optional — defaults shown).
PG_POOL_MAX=10
PG_IDLE_TIMEOUT=30000
PG_CONN_TIMEOUT=2000

# ----------------------------------------------------------------------------
# Authentication
# ----------------------------------------------------------------------------

# Secret used to sign and verify JWT tokens. REQUIRED in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-strong-random-secret-here

# ----------------------------------------------------------------------------
# File Uploads
# ----------------------------------------------------------------------------

# Directory where uploaded files are temporarily stored.
# Defaults to /tmp which is cleared on process restart.
UPLOAD_DIR=/tmp

# ----------------------------------------------------------------------------
# Cloudinary — media/image hosting
# ----------------------------------------------------------------------------

# Your Cloudinary cloud name (visible in the Cloudinary dashboard).
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API key.
CLOUDINARY_API_KEY=your-api-key

# Cloudinary API secret. Keep this private — never expose in client code.
CLOUDINARY_API_SECRET=your-strong-cloudinary-secret-here

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------

# Comma-separated list of allowed origins in production.
# Example: "https://app.example.com,https://admin.example.com"
# In development all origins are accepted regardless of this value.
CORS_ORIGINS=https://app.example.com

# ----------------------------------------------------------------------------
# CSRF
# ----------------------------------------------------------------------------

# Set to "true" to disable CSRF validation (useful for automated testing).
# Should NEVER be "true" in production.
DISABLE_CSRF=false

# ----------------------------------------------------------------------------
# Firebase (optional — only needed if Firebase features are enabled)
# ----------------------------------------------------------------------------

# Firebase GCP project identifier.
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase service-account private key (PEM format, with literal \n newlines).
FIREBASE_PRIVATE_KEY=your-firebase-private-key-here

# ----------------------------------------------------------------------------
# YouTube integration (optional)
# ----------------------------------------------------------------------------

# YouTube Data API v3 key — used by GET /api/youtube/status.
YOUTUBE_API_KEY=your-youtube-api-key

# Target YouTube channel ID for subscriber-count checks.
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# Feature flags / development overrides
# ----------------------------------------------------------------------------

# Comma-separated list of admin email addresses.
# Users with these emails receive elevated privileges.
ADMIN_EMAILS=admin@example.com

# Set to "true" to allow admin deposit endpoints in development.
DEV_ALLOW_ADMIN_DEPOSIT=false

# Set to "true" to disable the background event processor loop.
EVENT_PROCESSOR_DISABLED=false
